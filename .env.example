# Copy to .env.local and fill in. Restart the dev server after changes.

# --- AI assistant (OpenAI) ---
OPENAI_API_KEY=
# Optional: override the model (defaults to gpt-4o)
# OPENAI_MODEL=gpt-4o

# --- Supabase (auth + data) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Voice (Vapi) + SMS/sending (Twilio) ---
VAPI_PRIVATE_KEY=
VAPI_PUBLIC_KEY=
# REQUIRED in production: shared secret Vapi sends as the x-vapi-secret header.
# The voice webhooks FAIL CLOSED without it (every call is rejected), so it must
# match the value configured on the Vapi assistant + phone number.
VAPI_SERVER_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+14752703374
# DEV ONLY: set to 1 to skip Twilio request-signature validation. Never set in
# production (it is force-ignored when NODE_ENV=production).
# TWILIO_SKIP_VALIDATION=

# --- App ---
# Public base URL, used for share links and assistant invites.
NEXT_PUBLIC_SITE_URL=https://pheme.deals
# Signs share/sign capability links (HMAC). Optional: falls back to the
# service-role key if unset. Recommended to set a dedicated 32+ byte random
# value so rotating the DB key doesn't invalidate links — but note that
# CHANGING this value invalidates all outstanding share/sign links.
SHARE_SECRET=

# --- Email delivery (Resend) — enables emailing filled PDFs ---
# Create a key at resend.com and verify the sending domain (pheme.deals).
RESEND_API_KEY=
EMAIL_FROM=Pheme <documents@pheme.deals>
