# Copy to .env.local and fill in. Restart the dev server after changes.

# --- AI assistant (required to enable the chat / phone brain) ---
OPENAI_API_KEY=
# Optional: override the model (defaults to gpt-4o)
# OPENAI_MODEL=gpt-4o

# --- Supabase (optional; app uses a local file store until these are set) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side key (preferred for writes). Use the service role key.
SUPABASE_SERVICE_ROLE_KEY=

# --- Phase 2: voice + SMS (not wired yet) ---
# VAPI_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
