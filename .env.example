# --- Voice (Vapi) + SMS/sending (Twilio) ---
VAPI_PRIVATE_KEY=
VAPI_PUBLIC_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+14752703374

# --- App ---
